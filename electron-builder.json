{
  "appId": "com.ovidra.desktop",
  "productName": "Ovidra",
  "copyright": "Copyright © 2026 Ovidra",
  "directories": {
    "output": "dist_electron"
  },
  "files": [
    "dist/**/*",
    "build/**/*",
    "electron.cjs",
    "package.json"
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "publish": null
  },
  "nsis": {
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Ovidra"
  }
}
