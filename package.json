{
  "name": "ovidra-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:start": "electron .",
    "electron:build": "set ELECTRON_BUILD=true&& npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "framer-motion": "^12.42.2",
    "html2pdf.js": "^0.14.0",
    "jsbarcode": "^3.12.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/express": "^5.0.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
